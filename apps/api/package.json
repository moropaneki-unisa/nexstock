{
  "name": "@nexstock/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "build:prod": "npm run prisma:generate && npm run prisma:migrate && npm run build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",

    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",

    "deploy": "npm install --no-audit --no-fund && npm run build:prod"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "exceljs": "^4.4.0",
    "multer": "^1.4.5-lts.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "puppeteer": "^24.33.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.6",
    "streamifier": "^0.1.1",
    "xlsx": "^0.18.5",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
