generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum Plan {
  free
  pro
  business
}

enum PaymentProvider {
  paystack
}

enum PaymentStatus {
  pending
  success
  failed
}

enum ProductStatus {
  active
  archived
  draft
}

enum InventoryMovementType {
  adjustment
  sale
  purchase
  import
  sync
  manual
}

enum WebhookEvent {
  product_created
  product_updated
  inventory_updated
  webhook_test
}

enum DeliveryStatus {
  pending
  delivered
  failed
  dead
}

enum CustomFieldType {
  text
  number
  boolean
  select
  date
  json
}

enum IntegrationProvider {
  zoho
  shopify
  custom
}

enum IntegrationStatus {
  connected
  disconnected
  error
  expired
}

enum SyncStatus {
  running
  success
  failed
}

enum SyncDirection {
  pull
  push
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  passwordHash          String
  name                  String?
  emailVerifiedAt       DateTime?
  verificationOtpHash   String?
  verificationOtpExpiry DateTime?
  memberships           Membership[]
  refreshTokens         RefreshToken[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id                 String         @id @default(uuid())
  name               String
  slug               String         @unique
  plan               Plan           @default(free)
  stripeCustomerId   String?        @unique
  legalName          String?
  tradingName        String?
  registrationNo     String?
  vatNumber          String?
  industry           String?
  companySize        String?
  website            String?
  phone              String?
  billingEmail       String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  province           String?
  postalCode         String?
  country            String?
  skuPrefix          String?
  onboardingComplete Boolean        @default(false)
  nextSkuNumber      Int            @default(1)
  memberships        Membership[]
  products           Product[]
  customFields       CustomField[]
  apiKeys            ApiKey[]
  webhooks           Webhook[]
  inventoryLogs      InventoryLog[]
  integrations       Integration[]
  syncLogs           SyncLog[]
  payments           Payment[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([slug])
  @@index([skuPrefix])
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           UserRole     @default(member)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Payment {
  id               String          @id @default(uuid())
  organizationId   String
  provider         PaymentProvider @default(paystack)
  status           PaymentStatus   @default(pending)
  plan             Plan
  amount           Int
  currency         String          @default("ZAR")
  reference        String          @unique
  authorizationUrl String?
  paidAt           DateTime?
  payload          Json?
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId, createdAt])
  @@index([status])
}

model Product {
  id                String                    @id @default(uuid())
  organizationId    String
  name              String
  sku               String
  description       String?
  price             Decimal                   @db.Decimal(12, 2)
  cost              Decimal?                  @db.Decimal(12, 2)
  quantity          Int                       @default(0)
  lowStockLevel     Int                       @default(5)
  category          String?
  images            Json                      @default("[]")
  metadata          Json?
  status            ProductStatus             @default(active)
  deletedAt         DateTime?
  organization      Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants          ProductVariant[]
  inventoryLogs     InventoryLog[]
  customFieldValues ProductCustomFieldValue[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([organizationId, sku])
  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, sku])
  @@index([organizationId, category])
  @@index([organizationId, createdAt])
}

model CustomField {
  id             String                    @id @default(uuid())
  organizationId String
  key            String
  label          String
  type           CustomFieldType
  required       Boolean                   @default(false)
  options        Json                      @default("[]")
  defaultValue   Json?
  order          Int                       @default(0)
  isActive       Boolean                   @default(true)
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values         ProductCustomFieldValue[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, isActive])
  @@index([organizationId, order])
}

model ProductCustomFieldValue {
  id        String      @id @default(uuid())
  productId String
  fieldId   String
  value     Json
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([productId, fieldId])
  @@index([productId])
  @@index([fieldId])
}

model ProductVariant {
  id        String         @id @default(uuid())
  productId String
  name      String
  sku       String
  size      String?
  color     String?
  price     Decimal?       @db.Decimal(12, 2)
  cost      Decimal?       @db.Decimal(12, 2)
  quantity  Int            @default(0)
  metadata  Json?
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  logs      InventoryLog[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([productId, sku])
  @@index([productId])
}

model InventoryLog {
  id             String                @id @default(uuid())
  organizationId String
  productId      String
  variantId      String?
  type           InventoryMovementType
  quantityBefore Int
  quantityAfter  Int
  delta          Int
  reason         String?
  source         String?
  referenceId    String?
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())

  @@index([organizationId, createdAt])
  @@index([productId, createdAt])
  @@index([variantId])
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  keyHash        String       @unique
  keyPrefix      String
  scopes         Json         @default("[\"products:read\", \"products:write\"]")
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([keyPrefix])
}

model Webhook {
  id             String            @id @default(uuid())
  url            String
  secret         String
  events         Json              @default("[]")
  isActive       Boolean           @default(true)
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries     WebhookDelivery[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, isActive])
}

model WebhookDelivery {
  id          String         @id @default(uuid())
  webhookId   String
  event       String
  payload     Json
  status      DeliveryStatus @default(pending)
  attempt     Int            @default(0)
  statusCode  Int?
  response    String?
  nextRetryAt DateTime?
  deliveredAt DateTime?
  webhook     Webhook        @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([webhookId, status])
  @@index([status, nextRetryAt])
}

model Integration {
  id             String              @id @default(uuid())
  organizationId String
  provider       IntegrationProvider
  status         IntegrationStatus   @default(disconnected)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  config         Json?
  lastSyncAt     DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncLogs       SyncLog[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider, status])
}

model SyncLog {
  id             String              @id @default(uuid())
  organizationId String
  integrationId  String
  provider       IntegrationProvider
  direction      SyncDirection
  status         SyncStatus
  summary        Json?
  error          String?
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration    Integration         @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId, startedAt])
  @@index([integrationId, status])
}
