generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum Plan {
  free
  starter
  growth
  business
}

enum PaymentProvider {
  paystack
  paddle
}

enum PaymentStatus {
  pending
  success
  failed
}

enum ProductStatus {
  active
  archived
  draft
}

enum SupplierStatus {
  active
  archived
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum InventoryMovementType {
  adjustment
  sale
  purchase
  import
  sync
  manual
}

enum WebhookEvent {
  product_created
  product_updated
  inventory_updated
  webhook_test
}

enum DeliveryStatus {
  pending
  delivered
  failed
  dead
}

enum CustomFieldType {
  text
  number
  boolean
  select
  date
  json
}

enum IntegrationProvider {
  zoho
  shopify
  custom
}

enum IntegrationStatus {
  connected
  disconnected
  error
  expired
}

enum SyncStatus {
  running
  success
  failed
}

enum SyncDirection {
  pull
  push
}

model User {
  id                    String         @id @default(uuid())
  email                 String         @unique
  passwordHash          String
  name                  String?
  emailVerifiedAt       DateTime?
  verificationOtpHash   String?
  verificationOtpExpiry DateTime?
  memberships           Membership[]
  refreshTokens         RefreshToken[]
  tasks                 Task[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Organization {
  id                 String         @id @default(uuid())
  name               String
  slug               String         @unique
  plan               Plan           @default(free)
  stripeCustomerId   String?        @unique
  legalName          String?
  tradingName        String?
  registrationNo     String?
  vatNumber          String?
  industry           String?
  companySize        String?
  website            String?
  phone              String?
  billingEmail       String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  province           String?
  postalCode         String?
  country            String?
  skuPrefix          String?
  baseCurrency       String         @default("ZAR")
  enabledCurrencies  String[]       @default(["ZAR"])
  exchangeRates      Json?
  onboardingComplete Boolean        @default(false)
  nextSkuNumber      Int            @default(1)
  memberships        Membership[]
  products           Product[]
  suppliers          Supplier[]
  customFields       CustomField[]
  apiKeys            ApiKey[]
  webhooks           Webhook[]
  inventoryLogs      InventoryLog[]
  integrations       Integration[]
  syncLogs           SyncLog[]
  payments           Payment[]
  tasks              Task[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([slug])
  @@index([skuPrefix])
  @@index([baseCurrency])
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           UserRole     @default(member)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Payment {
  id               String          @id @default(uuid())
  organizationId   String
  provider         PaymentProvider @default(paystack)
  status           PaymentStatus   @default(pending)
  plan             Plan
  amount           Int
  currency         String          @default("USD")
  reference        String          @unique
  authorizationUrl String?
  paidAt           DateTime?
  payload          Json?
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId, createdAt])
  @@index([status])
}

model Task {
  id                 String       @id @default(uuid())
  organizationId     String
  userId             String
  title              String
  description        String?
  status             TaskStatus   @default(todo)
  priority           TaskPriority @default(medium)
  category           String?
  dueAt              DateTime?
  reminderEnabled    Boolean      @default(false)
  reminderAt         DateTime?
  reminderSentAt     DateTime?
  completedAt        DateTime?
  metadata           Json?
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@index([userId, dueAt])
  @@index([reminderEnabled, reminderAt, reminderSentAt])
}

model Supplier {
  id              String            @id @default(uuid())
  organizationId  String
  name            String
  supplierType    String            @default("vendor")
  category        String?
  rating          String            @default("unrated")
  contactName     String?
  email           String?
  phone           String?
  website         String?
  addressLine1    String?
  addressLine2    String?
  country         String?
  province        String?
  city            String?
  postalCode      String?
  currency        String            @default("USD")
  paymentTerms    String?
  paymentMethod   String?
  taxStatus       String            @default("unknown")
  taxNumber       String?
  shippingTerms   String?
  incoterm        String?
  accountNumber   String?
  leadTimeDays    Int?
  minimumOrderQty Int?
  lastOrderAt     DateTime?
  notes           String?
  customFields    Json?
  status          SupplierStatus    @default(active)
  metadata        Json?
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products        ProductSupplier[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, status])
  @@index([organizationId, currency])
  @@index([organizationId, country])
  @@index([organizationId, supplierType])
  @@index([organizationId, category])
  @@index([organizationId, rating])
}

model ProductSupplier {
  id              String    @id @default(uuid())
  organizationId  String
  productId       String
  supplierId      String
  supplierSku     String?
  cost            Decimal?  @db.Decimal(12, 2)
  currency        String    @default("USD")
  minimumOrderQty Int?
  leadTimeDays    Int?
  isPreferred     Boolean   @default(false)
  lastPurchaseAt  DateTime?
  notes           String?
  metadata        Json?
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier        Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([productId, supplierId])
  @@index([organizationId, productId])
  @@index([organizationId, supplierId])
  @@index([organizationId, isPreferred])
}

model Product {
  id                 String                    @id @default(uuid())
  organizationId     String
  name               String
  sku                String
  description        String?
  price              Decimal                   @db.Decimal(12, 2)
  priceCurrency      String                    @default("ZAR")
  cost               Decimal?                  @db.Decimal(12, 2)
  costCurrency       String?
  exchangeRateToBase Decimal?                  @db.Decimal(18, 6)
  convertedCost      Decimal?                  @db.Decimal(12, 2)
  quantity           Int                       @default(0)
  lowStockLevel      Int                       @default(5)
  category           String?
  images             String[]                  @default([])
  metadata           Json?
  status             ProductStatus             @default(active)
  deletedAt          DateTime?
  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variants           ProductVariant[]
  inventoryLogs      InventoryLog[]
  customFieldValues  ProductCustomFieldValue[]
  productSuppliers   ProductSupplier[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@unique([organizationId, sku])
  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, sku])
  @@index([organizationId, category])
  @@index([organizationId, createdAt])
  @@index([organizationId, priceCurrency])
  @@index([organizationId, costCurrency])
}

model CustomField {
  id             String                    @id @default(uuid())
  organizationId String
  key            String
  label          String
  type           CustomFieldType
  required       Boolean                   @default(false)
  options        String[]                  @default([])
  defaultValue   Json?
  order          Int                       @default(0)
  isActive       Boolean                   @default(true)
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values         ProductCustomFieldValue[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, isActive])
  @@index([organizationId, order])
}

model ProductCustomFieldValue {
  id        String      @id @default(uuid())
  productId String
  fieldId   String
  value     Json
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([productId, fieldId])
  @@index([productId])
  @@index([fieldId])
}

model ProductVariant {
  id        String         @id @default(uuid())
  productId String
  name      String
  sku       String
  size      String?
  color     String?
  price     Decimal?       @db.Decimal(12, 2)
  cost      Decimal?       @db.Decimal(12, 2)
  quantity  Int            @default(0)
  metadata  Json?
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  logs      InventoryLog[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([productId, sku])
  @@index([productId])
}

model InventoryLog {
  id             String                @id @default(uuid())
  organizationId String
  productId      String
  variantId      String?
  type           InventoryMovementType
  quantityBefore Int
  quantityAfter  Int
  delta          Int
  reason         String?
  source         String?
  referenceId    String?
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())

  @@index([organizationId, createdAt])
  @@index([productId, createdAt])
  @@index([variantId])
}

model ApiKey {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  keyHash        String       @unique
  keyPrefix      String
  scopes         String[]     @default(["products:read", "products:write"])
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([keyPrefix])
}

model Webhook {
  id             String            @id @default(uuid())
  url            String
  secret         String
  events         WebhookEvent[]
  isActive       Boolean           @default(true)
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries     WebhookDelivery[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId, isActive])
}

model WebhookDelivery {
  id          String         @id @default(uuid())
  webhookId   String
  event       String
  payload     Json
  status      DeliveryStatus @default(pending)
  attempt     Int            @default(0)
  statusCode  Int?
  response    String?
  nextRetryAt DateTime?
  deliveredAt DateTime?
  webhook     Webhook        @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([webhookId, status])
  @@index([status, nextRetryAt])
}

model Integration {
  id             String              @id @default(uuid())
  organizationId String
  provider       IntegrationProvider
  status         IntegrationStatus   @default(disconnected)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  config         Json?
  lastSyncAt     DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncLogs       SyncLog[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider, status])
}

model SyncLog {
  id             String              @id @default(uuid())
  organizationId String
  integrationId  String
  provider       IntegrationProvider
  direction      SyncDirection
  status         SyncStatus
  summary        Json?
  error          String?
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration    Integration         @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId, startedAt])
  @@index([integrationId, status])
}
