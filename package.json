{
  "name": "inventoryhub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w @inventoryhub/api\" \"npm run dev -w @inventoryhub/web\"",
    "build": "npm run build -w @inventoryhub/api && npm run build -w @inventoryhub/web",
    "api": "npm run start:dev -w @inventoryhub/api",
    "web": "npm run dev -w @inventoryhub/web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
