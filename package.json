{
  "name": "nexstock",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w @nexstock/api\" \"npm run dev -w @nexstock/web\"",
    "build": "npm run build -w @nexstock/api && npm run build -w @nexstock/web",
    "build:web": "npm run build -w @nexstock/web",
    "build:api": "npm run build -w @nexstock/api",
    "api": "npm run start:dev -w @nexstock/api",
    "web": "npm run dev -w @nexstock/web",
    "prisma:generate": "npm run prisma:generate -w @nexstock/api",
    "migrate": "npm run migrate:deploy",
    "migrate:deploy": "npm run prisma:migrate -w @nexstock/api",
    "deploy:api": "npm install && npm run prisma:generate && npm run migrate && npm run build:api",
    "deploy:web": "npm install && npm run build:web",
    "deploy": "npm run deploy:api && npm run build:web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
