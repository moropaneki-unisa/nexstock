{
  "name": "nexstock",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w @nexstock/api\" \"npm run dev -w @nexstock/web\"",
    "build": "npm run build -w @nexstock/api && npm run build -w @nexstock/web",
    "api": "npm run start:dev -w @nexstock/api",
    "web": "npm run dev -w @nexstock/web",
    "postinstall": "cd apps/api && npx prisma generate",
    "migrate": "npm run migrate:deploy",
    "migrate:deploy": "cd apps/api && npx prisma migrate deploy",
    "deploy": "npm install && npm run migrate && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
